# Edge reverse proxy for the preprod host, behind Cloudflare's proxy (orange
# cloud, SSL mode Full (strict)). Cloudflare terminates TLS at its edge and
# re-originates HTTPS to this host, so Caddy serves a Cloudflare Origin CA cert
# (mounted at /certs) instead of Let's Encrypt: ACME can't validate behind the
# proxy (TLS-ALPN-01 is intercepted, the origin IP is hidden). $DOMAIN is
# injected by docker-compose.yml.
#
# admin/api are flat single-level subdomains (igsn-admin, igsn-api), not
# admin.$DOMAIN/api.$DOMAIN: Cloudflare's *.$DOMAIN cert covers only one label
# deep, so nested hosts would fail the TLS handshake.
#
#   frontend  https://igsn.{$DOMAIN}
#   admin     https://igsn-admin.{$DOMAIN}
#   api       https://igsn-api.{$DOMAIN}

# The Cloudflare Origin CA cert covers *.{$DOMAIN}, so all three sites share it.
# Operator copies origin.pem/origin.key to the host (see
# docs/preprod-deploy.md); they are secrets, never committed.
(edgetls) {
	tls /certs/origin.pem /certs/origin.key
}

# Security headers required on every app response (set at the edge, per
# .claude/rules/security-infra.md).
(sechdrs) {
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
		-Server
	}
	# ponytail: nonce-based CSP still to add; it needs per-request nonces emitted
	# by the SSR/SPA apps, so it lives with the apps, not here. Add when the apps
	# emit matching nonces.
}

igsn.{$DOMAIN} {
	import edgetls
	import sechdrs
	reverse_proxy frontend:8080
}

igsn-admin.{$DOMAIN} {
	import edgetls
	import sechdrs
	reverse_proxy admin:8080
}

igsn-api.{$DOMAIN} {
	import edgetls
	import sechdrs
	reverse_proxy api:8080
}
