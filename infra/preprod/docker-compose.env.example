# Copy to docker-compose.env, fill in, then copy that file to the preprod host's
# home directory before running `make preprod-deploy`. It holds the Postgres
# password, so the real docker-compose.env is gitignored.
#
# DOMAIN is the Cloudflare zone whose {igsn.,igsn-admin.,igsn-api.} A records point
# at the host EIP (single-level subdomains, covered by the *.DOMAIN cert). The
# DATABASE_* values seed the Postgres container on first boot; pick a strong
# password.

DOMAIN=igsn.example.org
DATABASE_NAME=igsn
DATABASE_USER=igsn
DATABASE_PASSWORD=change-me
