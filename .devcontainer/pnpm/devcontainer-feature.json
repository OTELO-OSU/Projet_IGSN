{
  "id": "pnpm",
  "version": "1.0.0",
  "name": "PNPM",
  "postCreateCommand": "pnpm install",
  "mounts": [
    {
      "type": "volume",
      "source": "${devcontainerId}-node-modules",
      "target": "/workspaces/projet-igsn/node_modules"
    },
    {
      "type": "volume",
      "source": "${devcontainerId}-pnpm-store",
      "target": "/workspaces/projet-igsn/.pnpm-store"
    },
    {
      "type": "volume",
      "source": "${devcontainerId}-pnpm",
      "target": "/mnt/pnpm"
    }
  ]
}
