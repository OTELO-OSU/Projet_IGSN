{
  "realm": "igsn",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "accessTokenLifespan": 300,
  "ssoSessionIdleTimeout": 1800,
  "revokeRefreshToken": true,
  "refreshTokenMaxReuse": 0,
  "roles": {
    "realm": [{ "name": "admin", "description": "IGSN administrator" }]
  },
  "clients": [
    {
      "clientId": "igsn-admin",
      "name": "IGSN Admin SPA",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": ["${ADMIN_REDIRECT_URI:http://localhost:3001/*}"],
      "webOrigins": ["${ADMIN_WEB_ORIGIN:http://localhost:3001}"],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "${ADMIN_REDIRECT_URI:http://localhost:3001/*}"
      },
      "protocolMappers": [
        {
          "name": "identity-provider",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usersessionmodel-note-mapper",
          "config": {
            "user.session.note": "identity_provider",
            "claim.name": "identity_provider",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true"
          }
        },
        {
          "name": "igsn-api-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.custom.audience": "igsn-api",
            "access.token.claim": "true",
            "id.token.claim": "false"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "test",
      "enabled": true,
      "emailVerified": true,
      "email": "test@example.com",
      "firstName": "Test",
      "lastName": "User",
      "credentials": [
        { "type": "password", "value": "test", "temporary": false }
      ],
      "realmRoles": ["admin"]
    }
  ],
  "identityProviders": [
    {
      "alias": "shibboleth",
      "displayName": "Institution (Shibboleth)",
      "providerId": "saml",
      "enabled": true,
      "trustEmail": true,
      "firstBrokerLoginFlowAlias": "first broker login",
      "config": {
        "singleSignOnServiceUrl": "${SHIBBOLETH_SSO_URL:http://localhost:8081/simplesaml/saml2/idp/SSOService.php}",
        "singleLogoutServiceUrl": "${SHIBBOLETH_SLO_URL:http://localhost:8081/simplesaml/saml2/idp/SingleLogoutService.php}",
        "nameIDPolicyFormat": "urn:oasis:names:tc:SAML:2.0:nameid-format:persistent",
        "principalType": "ATTRIBUTE",
        "principalAttribute": "eduPersonPrincipalName",
        "postBindingResponse": "true",
        "postBindingAuthnRequest": "true",
        "wantAuthnRequestsSigned": "false",
        "validateSignature": "false",
        "syncMode": "IMPORT"
      }
    },
    {
      "alias": "orcid",
      "displayName": "ORCID",
      "providerId": "oidc",
      "enabled": true,
      "firstBrokerLoginFlowAlias": "first broker login",
      "config": {
        "clientId": "${ORCID_CLIENT_ID:igsn-broker}",
        "clientSecret": "${ORCID_CLIENT_SECRET:mock-orcid-secret}",
        "authorizationUrl": "${ORCID_AUTHORIZATION_URL:http://localhost:8080/realms/mock-orcid/protocol/openid-connect/auth}",
        "logoutUrl": "${ORCID_LOGOUT_URL:http://localhost:8080/realms/mock-orcid/protocol/openid-connect/logout}",
        "tokenUrl": "${ORCID_TOKEN_URL:http://localhost:8080/realms/mock-orcid/protocol/openid-connect/token}",
        "userInfoUrl": "${ORCID_USERINFO_URL:http://localhost:8080/realms/mock-orcid/protocol/openid-connect/userinfo}",
        "issuer": "${ORCID_ISSUER:http://localhost:8080/realms/mock-orcid}",
        "jwksUrl": "${ORCID_JWKS_URL:http://localhost:8080/realms/mock-orcid/protocol/openid-connect/certs}",
        "useJwksUrl": "true",
        "validateSignature": "true",
        "defaultScope": "${ORCID_SCOPE:openid profile}",
        "clientAuthMethod": "client_secret_post",
        "syncMode": "IMPORT"
      }
    }
  ],
  "identityProviderMappers": [
    {
      "name": "shibboleth-email",
      "identityProviderAlias": "shibboleth",
      "identityProviderMapper": "saml-user-attribute-idp-mapper",
      "config": {
        "syncMode": "INHERIT",
        "attribute.name": "email",
        "user.attribute": "email"
      }
    },
    {
      "name": "shibboleth-first-name",
      "identityProviderAlias": "shibboleth",
      "identityProviderMapper": "saml-user-attribute-idp-mapper",
      "config": {
        "syncMode": "INHERIT",
        "attribute.name": "firstName",
        "user.attribute": "firstName"
      }
    },
    {
      "name": "shibboleth-last-name",
      "identityProviderAlias": "shibboleth",
      "identityProviderMapper": "saml-user-attribute-idp-mapper",
      "config": {
        "syncMode": "INHERIT",
        "attribute.name": "lastName",
        "user.attribute": "lastName"
      }
    },
    {
      "name": "orcid-first-name",
      "identityProviderAlias": "orcid",
      "identityProviderMapper": "oidc-user-attribute-idp-mapper",
      "config": {
        "syncMode": "INHERIT",
        "claim": "given_name",
        "user.attribute": "firstName"
      }
    },
    {
      "name": "orcid-last-name",
      "identityProviderAlias": "orcid",
      "identityProviderMapper": "oidc-user-attribute-idp-mapper",
      "config": {
        "syncMode": "INHERIT",
        "claim": "family_name",
        "user.attribute": "lastName"
      }
    }
  ]
}
